 三、实验内容： 
 
 1．数组与基本统计： 
 
 问题分析 
 本阶段要求使用一维数组存储一个学生的5次平时成绩，实现基本统计功能。需要完成：
 1) 定义长度为5的整型数组存储成绩
 2) 从键盘输入5个成绩
 3) 计算平均分、最高分、最低分
 4) 对成绩进行排序输出
 
 源代码（分层缩进，注释函数的作用，输入输出参数的说明） 
 
#include <iostream>
#include <iomanip>
#include <algorithm>
using namespace std;

int main()
{
    int scores[5];  // 存储5次平时成绩的数组
    
    // 从键盘输入5个成绩
    for (int i = 0; i < 5; i++)
    {
        cin >> scores[i];
    }

    // 输出所有成绩
    cout << "所有成绩: ";
    for (int i = 0; i < 5; i++)
    {
        cout << scores[i] << " ";
    }
    cout << endl;

    // 计算总分、最高分、最低分
    double sum = 0;
    int MAX = scores[0];
    int MIN = scores[0];

    for (int i = 0; i < 5; i++)
    {
        sum += scores[i];
        if (scores[i] > MAX)
            MAX = scores[i];
        if (scores[i] < MIN)
            MIN = scores[i];
    }

    double average = sum / 5;  // 计算平均分

    // 输出统计结果
    cout << fixed << setprecision(2);
    cout << "平均分: " << average << endl;
    cout << "最高分: " << MAX << endl;
    cout << "最低分: " << MIN << endl;

    // 使用STL sort对成绩排序
    sort(scores, scores + 5);

    // 输出排序后的成绩
    cout << "成绩从高到低排序: ";
    for (auto &i : scores)
        cout << i << " ";
    cout << endl;

    return 0;
}
 
 算法分析 
 1. 时间复杂度：
    - 输入输出：O(n)，n=5
    - 遍历统计：O(n)
    - 排序：使用STL sort，时间复杂度O(n log n)
    - 总体时间复杂度：O(n log n)
 
 2. 空间复杂度：
    - 使用固定大小的数组，空间复杂度O(1)
 
 算法测试（测试算例，测试代码，测试结果） 
 测试输入：85 90 78 92 88
 预期输出：
 - 平均分：86.60
 - 最高分：92
 - 最低分：78
 - 排序后：78 85 88 90 92
 
 实际运行结果与预期一致。
 
 
 2．结构体、函数与文件读写： 
 
 问题分析 
 本阶段要求定义结构体存储学生完整信息，从CSV文件读取数据，计算总评成绩并排序输出。需要完成：
 1) 定义Student结构体，包含学号、姓名、手机号、5次平时成绩、考试成绩
 2) 实现readStudents函数从CSV读取数据
 3) 实现calcTotal函数计算总评（平时×0.1×5 + 考试×0.5）
 4) 实现sortByFinal函数按总评排序（冒泡排序）
 5) 实现outputStudents函数输出到CSV文件
 
 源代码（分层缩进，注释函数的作用，输入输出参数的说明） 
 
#include <iostream>
#include <fstream>
#include <iomanip>
#include <string>
#include <sstream>
#include <vector>
using namespace std;

// 学生结构体定义
struct Student
{
    long long id;       // 学号
    string name;        // 姓名
    string phone;       // 手机号码
    int small[5];       // 5次平时成绩
    int final;          // 考试成绩
};

/**
 * 从CSV文件读取学生数据
 * @param stu 存储学生的vector容器（引用传递，输出参数）
 * @param maxSize 最大读取数量
 * @param filename CSV文件名
 * @return 实际读取的学生数量
 */
int readStudents(vector<Student> &stu, int maxSize, string filename)
{
    ifstream ifs;
    ifs.open(filename);

    char buff[256];
    ifs.getline(buff, 255); // 读取表头，丢弃
    while (ifs.getline(buff, 255))
    {
        Student A;
        char id_str[20], name_str[50], phone_str[20];
        int s1, s2, s3, s4, s5, exam;

        // 使用sscanf解析CSV行
        sscanf(buff, "%[^,],%[^,],%[^,],%d,%d,%d,%d,%d,%d",
               id_str, name_str, phone_str, &s1, &s2, &s3, &s4, &s5, &exam);
        A.name = string(name_str);
        A.phone = string(phone_str);
        A.id = atoll(id_str);       // 字符串转long long
        A.small[0] = s1;            // 存储5次平时成绩
        A.small[1] = s2;
        A.small[2] = s3;
        A.small[3] = s4;
        A.small[4] = s5;
        A.final = exam;             // 存储考试成绩

        stu.push_back(A);
    }
    return stu.size();
}

/**
 * 计算单个学生的总评成绩
 * @param s 学生结构体（const引用，输入参数）
 * @return 总评成绩（double类型）
 * 计算公式：平时1×0.1 + 平时2×0.1 + 平时3×0.1 + 平时4×0.1 + 平时5×0.1 + 考试×0.5
 */
double calcTotal(const Student &s)
{
    double total = 0;
    for (int i = 0; i < 5; i++)
    {
        total += s.small[i] * 0.1;
    }
    total += s.final * 0.5;
    return total;
}

/**
 * 在控制台显示学生信息
 * @param s 学生结构体（const引用，输入参数）
 */
void printStudent(const Student &s)
{
    cout << "学号: " << s.id << "  ";
    cout << "姓名: " << s.name << "  ";
    cout << "平时成绩: ";
    for (int i = 0; i < 5; i++)
    {
        cout << s.small[i] << " ";
    }
    cout << " 考试成绩: " << s.final << "  ";
    cout << "总评: " << calcTotal(s) << endl;
}

/**
 * 按总评成绩对学生进行降序排序（冒泡排序）
 * @param stu 学生vector容器（引用传递，输入输出参数）
 * @param n 学生数量
 */
void sortByFinal(vector<Student> &stu, int n)
{
    for (int i = 0; i < n - 1; i++)
    {
        for (int j = 0; j < n - 1 - i; j++)
        {
            if (calcTotal(stu[j]) < calcTotal(stu[j + 1]))
            {
                Student temp = stu[j];
                stu[j] = stu[j + 1];
                stu[j + 1] = temp;
            }
        }
    }
}

/**
 * 将学生数据输出到CSV文件
 * @param stu 学生vector容器（const引用，输入参数）
 * @param n 学生数量
 * @param filename 输出文件名
 */
void outputStudents(vector<Student> &stu, int n, const char *filename)
{
    ofstream file(filename);

    file << "学号,姓名,手机号码,平时1,平时2,平时3,平时4,平时5,考试,总评" << endl;

    file << fixed << setprecision(2);
    for (int i = 0; i < n; i++)
    {
        file << stu[i].id << ",";
        file << stu[i].name << ",";
        file << stu[i].phone << ",";
        for (int j = 0; j < 5; j++)
        {
            file << stu[i].small[j] << ",";
        }
        file << stu[i].final << ",";
        file << calcTotal(stu[i]) << endl;
    }

    file.close();
    cout << "数据已写入文件: " << filename << endl;
}

int main()
{
    const int MAX_SIZE = 100;
    vector<Student> stu;
    stu.reserve(MAX_SIZE);

    int n = readStudents(stu, MAX_SIZE, "pracA.csv");

    cout << "读取到 " << n << " 个学生数据:" << endl;
    for (int i = 0; i < n; i++)
    {
        printStudent(stu[i]);
    }

    sortByFinal(stu, n);

    cout << endl << "按总评成绩排序后:" << endl;
    for (int i = 0; i < n; i++)
    {
        printStudent(stu[i]);
    }

    outputStudents(stu, n, "sorted.csv");

    return 0;
}
 
 算法分析 
 1. 时间复杂度：
    - readStudents：O(n)，n为学生数量
    - calcTotal：O(1)
    - sortByFinal（冒泡排序）：O(n²)
    - outputStudents：O(n)
    - 总体时间复杂度：O(n²)
 
 2. 空间复杂度：
    - 使用vector存储学生数据，空间复杂度O(n)
    - 冒泡排序是原地排序，额外空间O(1)
    - 总体空间复杂度：O(n)
 
 3. 排序算法分析：
    - 采用冒泡排序，时间复杂度O(n²)，空间复杂度O(1)
    - 对于80个学生的数据规模，性能可接受
    - 若数据量增大，建议改用快速排序O(n log n)
 
 算法测试（测试算例，测试代码，测试结果） 
 测试数据：pracA.csv 包含80个学生的成绩数据
 测试内容：
 1. 成功读取所有学生数据
 2. 正确计算总评成绩（验证公式：平时平均×0.5 + 考试×0.5）
 3. 按总评降序排序正确
 4. 输出文件sorted.csv格式正确
 
 排序结果验证（前3名）：
 - 第1名：李孟哲，总评94.80
 - 第2名：王子博，总评92.90
 - 第3名：聂斌，总评92.70
 
 
 3．类的初步封装 
 
 问题分析 
 本阶段要求将阶段二中的结构体改为类，体会封装思想。需要完成：
 1) 定义Student类，数据成员设为私有，提供公有成员函数
 2) 定义Course类，封装学生数组和相关操作
 3) 实现构造函数、set/get方法、计算总评、显示信息等功能
 4) 通过类的成员函数完成文件读写和排序
 
 源代码（分层缩进，注释函数的作用，输入输出参数的说明） 
 
#include <iostream>
#include <fstream>
#include <iomanip>
#include <string>
#include <vector>
#include <algorithm>
using namespace std;

/**
 * Student类：封装学生信息和操作
 */
class Student
{
private:
    long long id;       // 学号（私有）
    string name;        // 姓名（私有）
    string phone;       // 手机号（私有）
    double small[5];    // 5次平时成绩（私有）
    double final;       // 考试成绩（私有）

public:
    // 默认构造函数
    Student()
    {
        id = 0; name = ""; phone = "";
        for (int i = 0; i < 5; i++) small[i] = 0;
        final = 0;
    }

    // 带参数的构造函数
    Student(long long id, const char *name, const char *phone, const int *s, int f);

    // Set方法（用于设置私有成员）
    void setId(long long id) { this->id = id; }
    void setName(string name) { this->name = name; }
    void setPhone(string phone) { this->phone = phone; }
    void setScore(int index, int score);
    void setFinal(int f) { final = f; }

    // Get方法（用于获取私有成员）
    long long getId() const { return id; }
    string getName() const { return name; }
    string getPhone() const { return phone; }
    double getScore(int index) const { return small[index]; }
    double getFinal() const { return final; }

    // 计算总评成绩
    double calcFinal() const;
    
    // 显示学生信息
    void display() const;
    
    // 从输入流读取数据
    void readStream(istream &in);
    
    // 向输出流写入数据
    void writeStream(ostream &out) const;
};

/**
 * Course类：封装课程的所有学生信息
 */
class Course
{
private:
    vector<Student> students;   // 学生数组（私有）
    int count;                  // 学生数量（私有）

public:
    // 构造函数
    Course() : count(0) {}

    // 添加学生
    void addStudent(const Student &s);
    
    // 打印所有学生信息
    void printallstudent() const;
    
    // 按总评排序
    void sortByFinal();
    
    // 从文件读取
    void readfromfile(const char *filename);
    
    // 写入文件
    void writetofile(const char *filename) const;
};

// Student类成员函数实现
void Student::setScore(int index, int score)
{
    if (index >= 0 && index < 5)
        small[index] = score;
}

double Student::calcFinal() const
{
    double total = 0;
    for (int i = 0; i < 5; i++)
        total += small[i] * 0.1;
    total += final * 0.5;
    return total;
}

void Student::display() const
{
    cout << "学号: " << id << "  ";
    cout << "姓名: " << name << "  ";
    cout << "平时成绩: ";
    for (int i = 0; i < 5; i++)
        cout << small[i] << " ";
    cout << " 考试成绩: " << final << "  ";
    cout << fixed << setprecision(2) << "总评: " << calcFinal() << endl;
}

void Student::readStream(istream &in)
{
    char buff[256];
    in.getline(buff, 255);
    char id_str[20], name_str[50], phone_str[20];
    sscanf(buff, "%[^,],%[^,],%[^,],%lf,%lf,%lf,%lf,%lf,%lf", 
           id_str, name_str, phone_str,
           &small[0], &small[1], &small[2], &small[3], &small[4], &final);
    id = atoll(id_str);
    name = string(name_str);
    phone = string(phone_str);
}

void Student::writeStream(ostream &out) const
{
    out << id << "," << name << "," << phone << ",";
    for (int i = 0; i < 5; i++)
        out << small[i] << ",";
    out << final << "," << fixed << setprecision(2) << calcFinal() << endl;
}

// Course类成员函数实现
void Course::addStudent(const Student &s)
{
    students.push_back(s);
    count++;
}

void Course::printallstudent() const
{
    for (const auto &s : students)
        s.display();
}

void Course::sortByFinal()
{
    sort(students.begin(), students.end(), 
         [](const Student &a, const Student &b)
         { return a.calcFinal() > b.calcFinal(); });
}

void Course::readfromfile(const char *filename)
{
    ifstream ifs(filename);
    char small[256];
    ifs.getline(small, 255); // 丢弃表头
    while (!ifs.eof())
    {
        Student s;
        s.readStream(ifs);
        this->addStudent(s);
    }
    if (this->count != 0)
        students.pop_back();  // 删除多读的空记录
    ifs.close();
}

void Course::writetofile(const char *filename) const
{
    ofstream ofs(filename);
    for (const auto &s : students)
        s.writeStream(ofs);
    ofs.close();
}

int main()
{
    Course course;                          // 创建Course对象
    course.readfromfile("pracA.csv");       // 读取数据
    course.printallstudent();               // 显示所有学生
    course.sortByFinal();                   // 排序
    course.printallstudent();               // 显示排序结果
    course.writetofile("pracA_sorted.csv"); // 写入文件
    return 0;
}
 
 算法分析 
 1. 封装性分析：
    - Student类将数据成员设为private，通过public的set/get方法访问
    - Course类封装了学生数组，外部无法直接操作内部数据
    - 体现了面向对象的封装特性
 
 2. 时间复杂度：
    - 与阶段二相同，sortByFinal使用STL sort，时间复杂度O(n log n)
    - 总体时间复杂度：O(n log n)
 
 3. 空间复杂度：
    - 使用vector存储学生，空间复杂度O(n)
 
 4. 改进点：
    - 使用STL sort替代冒泡排序，效率更高
    - 使用lambda表达式简化比较逻辑
    - 通过类的方法组织代码，结构更清晰
 
 算法测试（测试算例，测试代码，测试结果） 
 测试数据：pracA.csv（80个学生）
 测试步骤：
 1. 调用readfromfile读取数据 → 成功读取80条记录
 2. 调用printallstudent显示 → 正确显示所有学生信息
 3. 调用sortByFinal排序 → 按总评降序排列
 4. 调用writetofile输出 → 生成pracA_sorted.csv文件
 
 排序结果验证：
 - 排序前第1个学生：蔡嘉瑞，总评85.20
 - 排序后第1个学生：李孟哲，总评94.80
 - 排序正确
 
 
 四、实验总结：
 
 1. 实验收获：
    - 掌握了C++数组、结构体、类的基本用法
    - 学会了使用fstream进行文件读写操作
    - 理解了面向对象封装的思想和实现方法
    - 掌握了CSV文件的解析方法（使用sscanf）
    - 学会了使用vector容器和STL算法
 
 2. 遇到的问题及解决方法：
    - 问题1：学号超出int范围导致数据错误
      解决：将id类型改为long long，使用atoll转换
    
    - 问题2：文件读取时多读了一个空记录
      解决：使用eof()判断文件结束，最后pop_back删除空记录
    
    - 问题3：控制台输出中文乱码
      解决：了解编码问题，CSV使用GBK编码，代码文件使用UTF-8
    
    - 问题4：sscanf格式字符串类型不匹配
      解决：%f对应float/double，%d对应int，注意类型一致
 
 3. 改进方向：
    - 可以使用更高效的排序算法（如快速排序）
    - 可以增加错误处理机制（如文件不存在、格式错误等）
    - 可以使用更现代的C++特性（如智能指针、异常处理等）
 
 4. 实验体会：
    通过本次实验，我深入理解了C++的基础语法和面向对象编程思想。
    从阶段一到阶段三，代码逐渐从面向过程转变为面向对象，
    结构更加清晰，可维护性更强。文件读写和CSV解析是实际开发中
    常用的技能，通过实践掌握了这些技术。
